<Window x:Class="LinkShot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LinkShot"
        Height="750"
        Width="1200"
        Background="#F3F2EF">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- LOGIN -->
        <Border Grid.Row="0"
                Background="White"
                Padding="15"
                Margin="0,0,0,15"
                CornerRadius="8"
                BorderBrush="#DCE6F1"
                BorderThickness="1">

            <StackPanel Orientation="Horizontal">

                <TextBox x:Name="UsernameBox"
                         Width="180"
                         Height="30"
                         Margin="0,0,10,0"/>

                <PasswordBox x:Name="PasswordBox"
                             Width="180"
                             Height="30"
                             Margin="0,0,10,0"/>

                <Button Content="Login"
                        Width="100"
                        Height="30"
                        Background="#0A66C2"
                        Foreground="White"
                        Click="Login_Click"/>

                <TextBlock x:Name="AuthStatusText"
                           Margin="15,5,0,0"
                           Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- POST EDITOR -->
        <Border Grid.Row="1"
                Background="White"
                Padding="15"
                Margin="0,0,0,15"
                CornerRadius="8"
                BorderBrush="#DCE6F1"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="Cross-Platform Post Manager"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBox x:Name="ContentBox"
                         Height="90"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         TextChanged="ContentBox_TextChanged"
                         Margin="0,0,0,10"/>

                <TextBox x:Name="ImageBox"
                         Height="30"
                         Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,10">

                    <CheckBox x:Name="LinkedInCheck"
                              Content="LinkedIn"
                              Margin="0,0,20,0"/>

                    <CheckBox x:Name="HandshakeCheck"
                              Content="Handshake"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">

                    <Button Content="Post"
                            Width="100"
                            Height="35"
                            Margin="0,0,10,0"
                            Background="#0A66C2"
                            Foreground="White"
                            Click="Post_Click"/>

                    <Button Content="Update"
                            Width="100"
                            Height="35"
                            Margin="0,0,10,0"
                            Background="#057642"
                            Foreground="White"
                            Click="Update_Click"/>

                    <Button Content="Delete"
                            Width="100"
                            Height="35"
                            Background="#B71C1C"
                            Foreground="White"
                            Click="DeleteSelected_Click"/>

                </StackPanel>

                <TextBlock x:Name="StatusText"
                           Margin="0,10,0,0"
                           Foreground="Gray"/>

                <TextBlock x:Name="CharacterCountText"
                           FontSize="11"
                           Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- SPLIT FEEDS -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LINKEDIN -->
            <Border Grid.Column="0"
                    Background="White"
                    Margin="0,0,10,0"
                    Padding="10"
                    CornerRadius="8"
                    BorderBrush="#DCE6F1"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="LinkedIn"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#0A66C2"
                               Margin="0,0,0,10"/>

                    <ListBox x:Name="LinkedInList"
                             SelectionChanged="LinkedInList_SelectionChanged">

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="#DCE6F1"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,0,0,8"
                                        Padding="8">

                                    <StackPanel>

                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding Timestamp}"
                                                   FontSize="10"
                                                   Foreground="Gray"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </StackPanel>
            </Border>

            <!-- HANDSHAKE -->
            <Border Grid.Column="1"
                    Background="White"
                    Padding="10"
                    CornerRadius="8"
                    BorderBrush="#DCE6F1"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="Handshake"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#B71C1C"
                               Margin="0,0,0,10"/>

                    <ListBox x:Name="HandshakeList"
                             SelectionChanged="HandshakeList_SelectionChanged">

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="#DCE6F1"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,0,0,8"
                                        Padding="8">

                                    <StackPanel>

                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding Timestamp}"
                                                   FontSize="10"
                                                   Foreground="Gray"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</Window>