<Window x:Class="LinkShot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LinkBridge" Height="500" Width="750"
        Background="#F3F2EF">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Card Container -->
        <Border Background="White" CornerRadius="8" Padding="15" BorderBrush="#DCE6F1" BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Create Post"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1D2226"
                           Margin="0,0,0,10"/>

                <!-- Content -->
                <TextBox x:Name="ContentBox"
                         Height="70"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Margin="0,0,0,8"
                         BorderBrush="#DCE6F1"
                         BorderThickness="1"
                         Padding="8" TextChanged="ContentBox_TextChanged"
                         />

                <!-- Image -->
                <TextBox x:Name="ImageBox"
                         Height="30"
                         Margin="0,0,0,8"
                         BorderBrush="#DCE6F1"
                         BorderThickness="1"
                         Padding="5"
                         />

                <!-- Platform Selection -->
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <CheckBox x:Name="LinkedInCheck"
                              Content="LinkedIn"
                              Margin="0,0,15,0"/>
                    <CheckBox x:Name="HandshakeCheck"
                              Content="Handshake"/>
                </StackPanel>

                <!-- Post Button -->
                <Button Content="Post"
                        Width="120"
                        Height="35"
                        Margin="0,10,0,0"
                        Background="#0A66C2"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="Post_Click"/>
            </StackPanel>
        </Border>

        <!-- Feed -->
        <ListBox Grid.Row="1"
                 x:Name="PostList"
                 Margin="0,15,0,0"
                 Background="Transparent"
                 BorderThickness="0">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,10"
                            BorderBrush="#DCE6F1"
                            BorderThickness="1">

                        <StackPanel>
                            <TextBlock Text="{Binding Content}"
                                       Foreground="#1D2226"
                                       TextWrapping="Wrap"
                                       FontSize="14"/>

                            <TextBlock Text="{Binding Timestamp}"
                                       FontSize="11"
                                       Foreground="Gray"
                                       Margin="0,5,0,0"/>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Delete"
                                        Tag="{Binding}"
                                        Click="Delete_Click"
                                        Background="#E7F3FF"
                                        Foreground="#0A66C2"
                                        BorderBrush="#0A66C2"
                                        BorderThickness="1"
                                        Padding="5,2"
                                        Margin="0,0,8,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>
        </Grid>
</Window>
